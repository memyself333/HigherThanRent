MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d29196126f9adcd4b86e181f933918be, type: 3}
  m_Name: Janitor Warning
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  lines:
  - speaker: {fileID: 11400000, guid: 37fb8352eeab2924cb1e1f086d59a641, type: 2}
    text: Hey, you there, Mr Fox!
  - speaker: {fileID: 11400000, guid: 10d6c4919aaba13499839fbcfdd1c2c6, type: 2}
    text: Who are you supposed to be?
  - speaker: {fileID: 11400000, guid: 37fb8352eeab2924cb1e1f086d59a641, type: 2}
    text: I'm the Janitor, do you not recognise me?
  - speaker: {fileID: 11400000, guid: 10d6c4919aaba13499839fbcfdd1c2c6, type: 2}
    text: Trust me, I can't recognise anything right now.
  - speaker: {fileID: 11400000, guid: 37fb8352eeab2924cb1e1f086d59a641, type: 2}
    text: Well anyway, I'm just here to warn you that the server room is flooding
      as we speak, so I wouldn't recommend you go up there, unless you're ready for
      a FIGHT with water and electricity.
  - speaker: {fileID: 11400000, guid: 10d6c4919aaba13499839fbcfdd1c2c6, type: 2}
    text: This sounds like some heavy foreshadowing, like there's a boss fight waiting
      for me.
  - speaker: {fileID: 11400000, guid: 37fb8352eeab2924cb1e1f086d59a641, type: 2}
    text: ...
  - speaker: {fileID: 11400000, guid: 37fb8352eeab2924cb1e1f086d59a641, type: 2}
    text: Who knooooooows?????
  - speaker: {fileID: 11400000, guid: 10d6c4919aaba13499839fbcfdd1c2c6, type: 2}
    text: Lemme go beat that boss.
