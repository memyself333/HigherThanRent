  m_Script: {fileID: 11500000, guid: d29196126f9adcd4b86e181f933918be, type: 3}
  m_Name: Save Sophie
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  lines:
  - speaker: {fileID: 11400000, guid: 22d59affd6ae02b4ea93ced5087599b0, type: 2}
    text: Hey there, did you know if you click that little save button there, you
      can save your progress so far.
  - speaker: {fileID: 11400000, guid: 10d6c4919aaba13499839fbcfdd1c2c6, type: 2}
    text: Saving? Like a game?
  - speaker: {fileID: 11400000, guid: 22d59affd6ae02b4ea93ced5087599b0, type: 2}
    text: Yeah! You know, for like if you die?
  - speaker: {fileID: 11400000, guid: 10d6c4919aaba13499839fbcfdd1c2c6, type: 2}
    text: huh
  - speaker: {fileID: 11400000, guid: 10d6c4919aaba13499839fbcfdd1c2c6, type: 2}
    text: D-Die?
  - speaker: {fileID: 11400000, guid: 22d59affd6ae02b4ea93ced5087599b0, type: 2}
    text: Good luck!
