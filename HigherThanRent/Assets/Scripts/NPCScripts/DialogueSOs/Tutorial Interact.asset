  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d29196126f9adcd4b86e181f933918be, type: 3}
  m_Name: Tutorial Interact
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSO
  lines:
  - speaker: {fileID: 11400000, guid: 22d59affd6ae02b4ea93ced5087599b0, type: 2}
    text: Hey, not so close to me! Use that on your enemies!
  - speaker: {fileID: 11400000, guid: 22d59affd6ae02b4ea93ced5087599b0, type: 2}
    text: And lastly, the fact that you're talking to me tells me you might have
      figured this out...
  - speaker: {fileID: 11400000, guid: 22d59affd6ae02b4ea93ced5087599b0, type: 2}
    text: Press the E key to interact with things. This way you can get helpful conversations!
      And maybe something really special-
  - speaker: {fileID: 11400000, guid: 10d6c4919aaba13499839fbcfdd1c2c6, type: 2}
    text: Special? Like treasure?
  - speaker: {fileID: 11400000, guid: 22d59affd6ae02b4ea93ced5087599b0, type: 2}
    text: Sure, if you happen to see a treasure chest!
  - speaker: {fileID: 11400000, guid: 22d59affd6ae02b4ea93ced5087599b0, type: 2}
    text: But why would there be treasure in an apartment building? HAHA-
  - speaker: {fileID: 11400000, guid: 22d59affd6ae02b4ea93ced5087599b0, type: 2}
    text: That should be all you need. Try not to lose your balance on the way out.
      Or trip on any of this mess...
  nextconvo: []
